% disk, df

# 显示文件系统使用率 (仅显示已挂载)
df -hT -x tmpfs -x devtmpfs -x efivarfs



% disk, lsblk

# 显示块设备结构 (包含未挂载)
lsblk -pf



% disk, fdisk

# 显示磁盘分区表 (包含未挂载)
sudo fdisk -l



% disk, udisksctl

# 显示物理驱动器列表
udisksctl status

# 挂载 U 盘 (插入后执行)
udisksctl mount -b /dev/sda1

# 卸载 U 盘
udisksctl unmount -b /dev/sda1

# 给 U 盘断电 (拔出前执行)
udisksctl power-off -b /dev/sda



% disk, fuser

# 显示挂载目录被哪些进程占用
sudo fuser -v /run/media/yz/EUNU
