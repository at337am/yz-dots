#!/usr/bin/env bash

set -euo pipefail

if [[ "$#" -ne 1 ]]; then
    printf "Error: Invalid arguments.\n" >&2
    printf "Usage: %s <file>\n" "$(basename "$0")" >&2
    exit 1
fi

# 定义颜色
RED='\033[0;31m'        # 红色
NC='\033[0m'            # 重置色

FILE="$1"

# 2. 提取后缀并转换为小写 (实现忽略大小写)
# ${FILE##*.} 获取最后一个 . 之后的内容
# ,, 是 Bash 4.0+ 的特性，将字符串转换为全小写
ext="${FILE##*.}"
ext="${ext,,}"

case "$ext" in
    jpg|jpeg|png|gif|webp)
        qimgv "$FILE"
        ;;
    mp4|mkv|mov|m4v|webm|ts|avi)
        mpv "$FILE"
        ;;
    pdf)
        zathura "$FILE"
        ;;
    *)
        printf "${RED}Error:${NC} Unknown file extension %s\n" "$ext" >&2
        ;;
esac
