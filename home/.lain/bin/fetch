#!/usr/bin/env bash

# -=-=--=-=--=-=--=-=--=-=--=-=--=-=--=-=--=-=--=-=--=-=-
# 脚本用途: 显示系统信息, 类似 fastfetch
# 只适用于 Linux 系统
# -=-=--=-=--=-=--=-=--=-=--=-=--=-=--=-=--=-=--=-=--=-=-

set -euo pipefail

# 定义颜色
B_CYAN='\033[1;36m'     # 青色加粗
B_BLACK='\033[1;30m'    # 黑色加粗
NC='\033[0m'            # 重置色

# ------------- os -------------
info_os="$(source /etc/os-release && echo "$PRETTY_NAME")"

# ------------- terminal -------------
info_term="${TERM:-${TERM_PROGRAM:-unknown}}"

# ------------- wm -------------
# 检查是否在运行 river 并获取版本
if pgrep -x river &> /dev/null; then
    wm_ver="$(river -version)"
    info_wm="river ${wm_ver}"
else
    info_wm="unknown"
fi

# ------------- kernal -------------
# 直接读取 /proc, 因为 uname -r 太慢了
read -r info_kernel < /proc/sys/kernel/osrelease

# ------------- uptime -------------
# 直接读取 /proc, 因为 uptime -p 太慢了

# 读取秒数 (去掉小数部分)
read -r up_seconds _ < /proc/uptime
up_seconds=${up_seconds%.*}

# 转换计算
days=$(( up_seconds / 86400 ))
hours=$(( (up_seconds % 86400) / 3600 ))
mins=$(( (up_seconds % 3600) / 60 ))

# 格式化输出 (例如 2d 7h 15m)
info_uptime=""
[[ $days -gt 0 ]] && info_uptime="${days}d "
[[ $hours -gt 0 ]] && info_uptime="${info_uptime}${hours}h "
info_uptime="${info_uptime}${mins}m"

# ------------- final output -------------
print_line() {
    printf "  ${B_CYAN}%-4s${B_BLACK} :: ${NC}%s\n" "$1" "$2"
}

echo
print_line "os"     "$info_os"
print_line "wm"     "$info_wm"
print_line "term"   "$info_term"
print_line "kern"   "$info_kernel"
print_line "up"     "$info_uptime"


# todo
# Disk 36.17 GiB / 249.93 GiB (14%) - ext4
# 显示 logo
# 只适用于 Linux 系统. 增加前置条件
