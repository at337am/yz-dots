#!/usr/bin/env bash

# -=-=--=-=--=-=--=-=--=-=--=-=--=-=--=-=--=-=--=-=--=-=-
# 脚本用途: 使用 ADB 推送文件/目录到 Android 设备
# -=-=--=-=--=-=--=-=--=-=--=-=--=-=--=-=--=-=--=-=--=-=-

set -euo pipefail

# 定义颜色
RED='\033[0;31m'        # 红色
GREEN='\033[0;32m'      # 绿色
BLUE='\033[0;34m'       # 蓝色
NC='\033[0m'            # 重置色

if ! command -v "adb" &> /dev/null; then
    printf "Error: Missing dependency: adb\n" >&2
    exit 1
fi

if [[ "$#" -eq 0 ]]; then
    printf "Error: Invalid argument.\n" >&2
    printf "Usage: %s <paths...>\n" "$(basename "$0")" >&2
    exit 1
fi

if [[ -z "$(adb devices | tail -n +2 | grep -v '^$')" ]]; then
    printf "Error: 未检测到任何 ADB 连接的设备\n" >&2
    exit 1
fi

target_dir="/sdcard/temp_dir_of_aps"

if ! adb shell "mkdir -p '$target_dir'"; then
    printf "Error: 在 ADB 设备上创建目录 '%s' 失败\n" "$target_dir" >&2
    exit 1
fi

for source in "$@"; do
    if [[ -e "$source" ]]; then
        file_size=$(du -sh --apparent-size "$source" | awk '{print $1}')
        printf "Pushing: ${GREEN}%s${NC}  Size: ${BLUE}%s${NC}\n" "$source" "$file_size"
        adb push "$source" "$target_dir"
        printf "\n"
    else
        printf "${RED}Error: '%s' does not exist.${NC}\n" "$source" >&2
    fi
done

printf "Done.\n"

notify-send "ADB push" "all files have been transferred."

complete_audio_file="/usr/share/sounds/freedesktop/stereo/complete.oga"

if [[ -f "$complete_audio_file" ]]; then
    paplay "$complete_audio_file"
fi
