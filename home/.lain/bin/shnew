#!/usr/bin/env bash

# -=-=--=-=--=-=--=-=--=-=--=-=--=-=--=-=--=-=--=-=--=-=-
# 脚本用途: 生成一个 shell 示例脚本文件
# -=-=--=-=--=-=--=-=--=-=--=-=--=-=--=-=--=-=--=-=--=-=-

set -euo pipefail

if [[ "$#" -ne 1 ]]; then
    printf "Error: Invalid arguments.\n" >&2
    printf "Usage: %s <script_name>\n" "$(basename "$0")" >&2
    exit 1
fi

template_path="$HOME/.local/share/shnew/example.sh"

# 无论用户是否输入 .sh 后缀, 都确保输出只有一个 .sh
output_path="${1%.sh}.sh"

if [[ ! -f "$template_path" ]]; then
    printf "Error: %s does not exist.\n" "$template_path" >&2
    exit 1
fi

cp -a "$template_path" "$output_path"

printf "Created -> %s\n" "$output_path"
