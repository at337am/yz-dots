#!/usr/bin/env bash

# -=-=--=-=--=-=--=-=--=-=--=-=--=-=--=-=--=-=--=-=--=-=-
# 脚本用途: 将一个或多个文件路径以 URI 形式复制到 Wayland 剪贴板
# -=-=--=-=--=-=--=-=--=-=--=-=--=-=--=-=--=-=--=-=--=-=-

set -euo pipefail

# 定义颜色
RED='\033[0;31m'        # 红色
BLUE='\033[0;34m'       # 蓝色
NC='\033[0m'            # 重置色

if ! command -v "wl-copy" &> /dev/null; then
    printf "Error: Missing dependency: wl-copy\n" >&2
    exit 1
fi

if [[ "$#" -eq 0 ]]; then
    printf "Error: Invalid arguments.\n" >&2
    printf "Usage: %s <files...>\n" "$(basename "$0")" >&2
    exit 1
fi

uri_list=""

for file in "$@"; do
    if [[ ! -f "$file" ]]; then
        printf "${RED}Error: '%s' is not a regular file.${NC}\n" "$file" >&2
        exit 1
    fi

    # 获取文件的绝对路径
    real_path=$(realpath "$file")
    uri_list="${uri_list}file://${real_path}\n"
done

if [[ -n "$uri_list" ]]; then
    printf "$uri_list" | wl-copy --type text/uri-list
    printf "${BLUE}Copied:${NC}\n"
    printf "$uri_list"
fi
