#!/usr/bin/env bash

set -euo pipefail

# 依赖检查
dependencies=("udisksctl" "notify-send")
for cmd in "${dependencies[@]}"; do
    if ! command -v "$cmd" &> /dev/null; then
        printf "Error: Missing dependency: %s\n" "$cmd" >&2
        exit 1
    fi
done

# 定义颜色
RED='\033[0;31m'        # 红色
GREEN='\033[0;32m'      # 绿色
NC='\033[0m'            # 重置色

# 配置变量
usb_dev="/dev/sda"
usb_part="/dev/sda1"

# 检查设备是否存在
check_dev_exists() {
    if [[ ! -b "$usb_dev" ]]; then
        printf "USB device %s not found\n" "$usb_dev" >&2
        exit 1
    fi
}

usage() {
    printf "Usage:\n"
    printf "  %s [flags]\n" "$(basename "$0")"
    printf "\nFlags:\n"
    printf "  -m, --mount           Mount the USB drive\n"
    printf "  -u, --unmount         Safely eject the USB drive (unmount and power off)\n"
    printf "  -s, --status          Check the current mount status of the USB drive\n"
    printf "  -h, --help            Show this help message\n"
}

confirm() {
    local prompt=${1:-"Do you want to continue?"}
    read -r -p "$prompt [y/N]: " choice
    case "${choice,,}" in
        y|yes) return 0 ;;
        *) return 1 ;;
    esac
}

# 查看 U 盘的挂载状态
check_dev_status() {
    if findmnt -n "$usb_part" &> /dev/null; then
        mount_path=$(findmnt -n -o TARGET "$usb_part")
        printf "USB drive (%s) has been mounted at: %s\n" "$usb_part" "$mount_path"
    else
        printf "USB drive (%s) is currently not mounted\n" "$usb_part"
    fi
}

# 挂载
do_mount() {
    if findmnt -n "$usb_part" &> /dev/null; then
        mount_path=$(findmnt -n -o TARGET "$usb_part")
        printf "USB drive (%s) has been mounted at: %s\n" "$usb_part" "$mount_path"
        exit 0
    fi

    udisksctl mount -b "$usb_part"
}

# 卸载, 断电
do_unmount() {
    if ! confirm "Are you sure you want to eject the USB drive?"; then
        printf "Operation cancelled.\n"
        exit 1
    fi

    if findmnt -n "$usb_part" &> /dev/null; then
        udisksctl unmount -b "$usb_part"
        printf "USB drive has been unmounted.\n"
    fi

    udisksctl power-off -b "$usb_dev"
    printf "USB drive has been safely removed.\n"
}

# 检查参数是否等于 1
if [[ "$#" -ne 1 ]]; then
    printf "Error: Invalid arguments.\n" >&2
    usage >&2
    exit 1
fi

# 主程序入口
case "$1" in
    -m|--mount)
        check_dev_exists
        do_mount
        ;;
    -u|--unmount)
        check_dev_exists
        do_unmount
        ;;
    -s|--status)
        check_dev_exists
        check_dev_status
        ;;
    -h|--help)
        usage
        exit 0
        ;;
    *)
        printf "${RED}Error: Unknown flag %s${NC}\n" "$1" >&2
        usage >&2
        exit 1
        ;;
esac
