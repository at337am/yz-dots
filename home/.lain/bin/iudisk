#!/usr/bin/env bash

# -=-=--=-=--=-=--=-=--=-=--=-=--=-=--=-=--=-=--=-=--=-=-
# 脚本用途: 为了简化 U 盘挂载、卸载、断电等操作
# -=-=--=-=--=-=--=-=--=-=--=-=--=-=--=-=--=-=--=-=--=-=-

set -euo pipefail

# 依赖检查
dependencies=("udisksctl" "lsblk" "findfs" "findmnt" "notify-send" "paplay")
for cmd in "${dependencies[@]}"; do
    if ! command -v "$cmd" &> /dev/null; then
        printf "Error: Missing dependency: %s\n" "$cmd" >&2
        exit 1
    fi
done

# 定义颜色
RED='\033[0;31m'        # 红色
GREEN='\033[0;32m'      # 绿色
MAGENTA='\033[0;35m'    # 紫色
NC='\033[0m'            # 重置色

# U 盘标签
TARGET_LABEL="IUDISK"

# 全局变量, 之后会由 detect_device 函数填充
usb_part=""
usb_dev=""

# 发送通知
notify() {
    notify-send -a "iudisk" \
                -u low \
                -h string:x-dunst-stack-tag:volume_notif \
                "$1"
}

# 播放音频
play_audio() {
    local audio_file="/usr/share/sounds/freedesktop/stereo/${1}.oga"
    [[ -f "$audio_file" ]] && paplay "$audio_file" &
}

# 通过标签探测设备
detect_device() {
    # 1. 查找分区
    if ! usb_part=$(findfs LABEL="$TARGET_LABEL" 2>/dev/null); then
        printf "${RED}Error: No device found with label '%s'${NC}\n" "$TARGET_LABEL" >&2
        exit 1
    fi

    # 2. 获取父设备
    # xargs: 去除首尾空白符
    usb_dev=$(lsblk -n -o pkname --paths "$usb_part" | xargs)

    # 3. 严格报错: 如果找不到父设备, 直接退出
    if [[ -z "$usb_dev" ]]; then
        printf "${RED}Error: Could not determine parent device for %s${NC}\n" "$usb_part" >&2
        exit 1
    fi

    # 额外的防御性检查: 确保找到的父设备真的是个块设备
    if [[ ! -b "$usb_dev" ]]; then
         printf "${RED}Error: Detected parent %s is not a block device.${NC}\n" "$usb_dev" >&2
         exit 1
    fi
}

usage() {
    printf "Usage:\n"
    printf "  %s [flags]\n" "$(basename "$0")"
    printf "\nTarget Label: ${MAGENTA}%s${NC}\n" "$TARGET_LABEL"
    printf "\nFlags:\n"
    printf "  -m, --mount           Mount the USB drive\n"
    printf "  -u, --unmount         Safely eject the USB drive (unmount and power off)\n"
    printf "  -s, --status          Check the current mount status\n"
    printf "  -h, --help            Show this help message\n"
}

confirm() {
    local prompt=${1:-"Do you want to continue?"}
    read -r -p "$prompt [y/N]: " choice
    case "${choice,,}" in
        y|yes) return 0 ;;
        *) return 1 ;;
    esac
}

# 查看 U 盘的挂载状态
# check_dev_status() {
#     if findmnt -n "$usb_part" &> /dev/null; then
#         mount_path=$(findmnt -n -o TARGET "$usb_part")
#         printf "USB drive [%s] (%s) is mounted at ${GREEN}%s${NC}\n" "$TARGET_LABEL" "$usb_part" "$mount_path"
#     else
#         printf "USB drive [%s] (%s) is detected but ${RED}not mounted${NC}\n" "$TARGET_LABEL" "$usb_part"
#     fi
# }

# 查看 U 盘的挂载状态
check_dev_status() {
    # 1. 获取设备详细信息 (大小, 文件系统)
    local size fstype
    read -r size fstype <<< "$(lsblk -d -n -o SIZE,FSTYPE "$usb_part" 2>/dev/null)"

    # 当出现空值时, 提供默认显示
    # 
    # 笔记: 这是参数扩展的写法, 相当于下面的伪代码:
    # if [[ -z "$size" ]]; then
    #     size="N/A"
    # else
    #     size=$size
    # fi
    size="${size:-N/A}"
    fstype="${fstype:-Unknown}"

    # 2. 定义样式常量
    local HR="------------------------------------------"

    # 3. 输出头部
    printf "${MAGENTA}%s${NC}\n" "$HR"
    printf " Device Info   ${MAGENTA}%s${NC}\n" "$TARGET_LABEL"
    printf "${MAGENTA}%s${NC}\n" "$HR"

    # 4. 输出基础信息
    printf " %-12s  %s\n" "Partition"  "$usb_part"
    printf " %-12s  %s\n" "Parent Dev" "$usb_dev"
    printf " %-12s  %s\n" "Size/Type"  "$size ($fstype)"

    # 5. 输出挂载状态
    if findmnt -n "$usb_part" &> /dev/null; then
        local mount_path
        mount_path=$(findmnt -n -o TARGET "$usb_part")

        printf " %-12s  ${GREEN}%s${NC}\n" "Status" "Mounted"
        printf " %-12s  %s\n" "Mount Point" "$mount_path"
    else
        printf " %-12s  ${RED}%s${NC}\n" "Status" "Unmounted"
    fi

    printf "${MAGENTA}%s${NC}\n" "$HR"
}

# 挂载
do_mount() {
    if findmnt -n "$usb_part" &> /dev/null; then
        mount_path=$(findmnt -n -o TARGET "$usb_part")
        printf "${MAGENTA}Already mounted at %s${NC}\n" "$mount_path"
        exit 0
    fi

    printf "Mounting '%s' (%s)...\n" "$TARGET_LABEL" "$usb_part"

    udisksctl mount -b "$usb_part"
    printf "${GREEN}Mounted successfully.${NC}\n"
}

# 卸载, 断电
do_unmount() {
    # 如果已经挂载, 先卸载
    if findmnt -n "$usb_part" &> /dev/null; then
        if ! confirm "Eject USB drive '$TARGET_LABEL'?"; then
            printf "Operation cancelled.\n" >&2
            exit 1
        fi

        udisksctl unmount -b "$usb_part"
        printf "${GREEN}Unmounted successfully.${NC}\n"
    else
        # 如果没挂载, 直接询问是否断电
        if ! confirm "Device not mounted. Power off '$TARGET_LABEL'?"; then
             exit 1
        fi
    fi

    # 断电操作针对的是父设备 (/dev/sda 而不是 /dev/sda1)
    udisksctl power-off -b "$usb_dev"
    printf "${GREEN}Device %s has been safely removed.${NC}\n" "$usb_dev"
}

# 检查参数
if [[ "$#" -ne 1 ]]; then
    printf "${RED}Error: Invalid arguments.${NC}\n" >&2
    usage >&2
    exit 1
fi

# 主程序入口
case "$1" in
    -m|--mount)
        detect_device
        do_mount
        notify "Mounted"
        play_audio "device-added"
        ;;
    -u|--unmount)
        detect_device
        do_unmount
        notify "Ejected"
        play_audio "device-removed"
        ;;
    -s|--status)
        detect_device
        check_dev_status
        ;;
    -h|--help)
        usage
        exit 0
        ;;
    *)
        printf "${RED}Error: Unknown flag %s${NC}\n" "$1" >&2
        usage >&2
        exit 1
        ;;
esac

# todo 未指定参数时, 执行 status
