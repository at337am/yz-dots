#!/usr/bin/env bash

set -euo pipefail

# 依赖检查
dependencies=("udisksctl" "notify-send")
for cmd in "${dependencies[@]}"; do
    if ! command -v "$cmd" &> /dev/null; then
        printf "Error: Missing dependency: %s\n" "$cmd" >&2
        exit 1
    fi
done

# 定义颜色
RED='\033[0;31m'        # 红色
GREEN='\033[0;32m'      # 绿色
MAGENTA='\033[0;35m'    # 紫色
NC='\033[0m'            # 重置色

# 定义 U 盘设备以及分区
usb_dev="/dev/sda"
usb_part="/dev/sda1"

# 发送通知
notify() {
    notify-send -a "iudisk" \
                -u low \
                -h string:x-dunst-stack-tag:volume_notif \
                "$1"
}

play_removed_audio() {
    local removed_audio_file="/usr/share/sounds/freedesktop/stereo/device-removed.oga"
    if [[ -f "$removed_sound_file" ]]; then
        paplay "$removed_sound_file"
    fi
}

play_added_audio() {
    local added_audio_file="/usr/share/sounds/freedesktop/stereo/device-added.oga"
    if [[ -f "$added_sound_file" ]]; then
        paplay "$added_sound_file"
    fi
}

# 检查设备是否存在
check_dev_exists() {
    if [[ ! -b "$usb_dev" ]]; then
        printf "${RED}USB device %s not found${NC}\n" "$usb_dev" >&2
        exit 1
    fi

    if [[ ! -b "$usb_part" ]]; then
        printf "${RED}USB partition %s not found on device %s${NC}\n" "$usb_part" "$usb_dev" >&2
        exit 1
    fi
}

usage() {
    printf "Usage:\n"
    printf "  %s [flags]\n" "$(basename "$0")"
    printf "\nFlags:\n"
    printf "  -m, --mount           Mount the USB drive\n"
    printf "  -u, --unmount         Safely eject the USB drive (unmount and power off)\n"
    printf "  -s, --status          Check the current mount status of the USB drive\n"
    printf "  -h, --help            Show this help message\n"
}

confirm() {
    local prompt=${1:-"Do you want to continue?"}
    read -r -p "$prompt [y/N]: " choice
    case "${choice,,}" in
        y|yes) return 0 ;;
        *) return 1 ;;
    esac
}

# 查看 U 盘的挂载状态
check_dev_status() {
    if findmnt -n "$usb_part" &> /dev/null; then
        mount_path=$(findmnt -n -o TARGET "$usb_part")
        printf "${GREEN}USB drive (%s) has been mounted at: %s${NC}\n" "$usb_part" "$mount_path"
    else
        printf "USB drive (%s) is not mounted\n" "$usb_part"
    fi
}

# 挂载
do_mount() {
    if findmnt -n "$usb_part" &> /dev/null; then
        mount_path=$(findmnt -n -o TARGET "$usb_part")
        printf "${MAGENTA}The USB drive is already mounted${NC}\n"
        exit 0
    fi

    udisksctl mount -b "$usb_part"
}

# 卸载, 断电
do_unmount() {
    if ! confirm "Are you sure you want to eject the USB drive?"; then
        printf "Operation cancelled.\n" >&2
        exit 1
    fi

    if findmnt -n "$usb_part" &> /dev/null; then
        udisksctl unmount -b "$usb_part"
        printf "${GREEN}USB drive has been unmounted${NC}\n"
    fi

    udisksctl power-off -b "$usb_dev"
    printf "${GREEN}USB drive has been safely removed${NC}\n"
}

# 检查参数是否等于 1
if [[ "$#" -ne 1 ]]; then
    printf "${RED}Error: Invalid arguments.${NC}\n" >&2
    usage >&2
    exit 1
fi

# 主程序入口
case "$1" in
    -m|--mount)
        check_dev_exists
        do_mount
        notify "Mounted"
        play_added_audio
        ;;
    -u|--unmount)
        check_dev_exists
        do_unmount
        notify "Ejected"
        play_removed_audio
        ;;
    -s|--status)
        check_dev_exists
        check_dev_status
        ;;
    -h|--help)
        usage
        exit 0
        ;;
    *)
        printf "${RED}Error: Unknown flag %s${NC}\n" "$1" >&2
        usage >&2
        exit 1
        ;;
esac
