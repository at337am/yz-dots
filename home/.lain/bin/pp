#!/usr/bin/env bash

# -=-=--=-=--=-=--=-=--=-=--=-=--=-=--=-=--=-=--=-=--=-=-
# 脚本用途: 设置壁纸
# -=-=--=-=--=-=--=-=--=-=--=-=--=-=--=-=--=-=--=-=--=-=-

set -euo pipefail

# 依赖检查
if ! command -v "swww" &> /dev/null; then
    printf "Error: Missing dependency: swww\n" >&2
    exit 1
fi

if [[ "$#" -ne 1 ]]; then
    printf "Error: Invalid argument.\n" >&2
    printf "Usage: %s <image>\n" "$(basename "$0")" >&2
    exit 1
fi

WALLPAPER_PATH="$1"

if [[ ! -f "$WALLPAPER_PATH" ]]; then
    printf "Error: %s does not exist.\n" "$WALLPAPER_PATH" >&2
    exit 1
fi

swww img "$WALLPAPER_PATH" --transition-type none

printf "Wallpaper has been changed to: %s\n" "$WALLPAPER_PATH"



# --- deprecated ---
# 
# WALLPAPER_PATH=$(realpath "$1")
# hyprctl hyprpaper preload "$WALLPAPER_PATH"
# hyprctl hyprpaper wallpaper ",$WALLPAPER_PATH"
