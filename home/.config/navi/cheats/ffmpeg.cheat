% ffmpeg, clip

# 模糊裁剪
ffmpeg -ss 00:00:30 -i input.mp4 -t 00:00:10 -c copy -avoid_negative_ts make_zero clip.mp4

# 精确裁剪, 保持画质尽可能无损
ffmpeg -ss 00:00:30 -i input.mp4 -t 00:00:10 -c:v libx264 -crf 18 -preset ultrafast -c:a copy clip.mp4



% ffmpeg, audio

# 去除音频流
ffmpeg -i input.mp4 -c:v copy -an noaudio.mp4



% ffmpeg, video

# 调整视频播放速度 (1.25x)
ffmpeg -i input.mp4 -vf "setpts=PTS/1.25" -af "atempo=1.25" -c:v libx264 -crf 18 -preset slow -c:a aac -b:a 256k output.mp4
