% pacman

# 更新系统 (相当于 upgrade)
sudo pacman -Syu

# 安装软件
sudo pacman -S xxx

# 删除软件包以及依赖
sudo pacman -Rns xxx

# 搜索软件包
pacman -Ss xxx

# 搜索已安装的软件
pacman -Qs xxx

# 列出所有已安装的软件
pacman -Q

# 查看已安装的软件信息
pacman -Qi xxx

# 清理未安装的软件包
sudo pacman --noconfirm -Sc

# 清理所有缓存
sudo pacman --noconfirm -Scc

# 修复损坏的软件包数据库
sudo pacman -Syyu