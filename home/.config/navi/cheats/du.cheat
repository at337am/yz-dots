% disk, du

# 列出当前路径下的文件/目录大小 (深度 1)
du -h --all --max-depth=1 .

# 列出当前路径下的文件/目录大小 (深度 1) - 显示实际数据量, 而非数据块
du -h --all --max-depth=1 --apparent-size .

# 只显示当前路径的总磁盘占用大小
du -h --summarize .



% disk, lsblk

# 显示所有块设备的完整路径和分区信息 (包括已挂载和未挂载的设备)
lsblk -fp



% disk, fdisk

# 列出所有磁盘及其分区表 (包括已挂载和未挂载的设备)
sudo fdisk -l



% disk, df

# 显示已挂载的文件系统的磁盘空间使用情况
df -hT
